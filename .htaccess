# ============================================
# VoloLeads Performance Optimization
# .htaccess - Apache Server Configuration
# ============================================

# Enable mod_rewrite for URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
</IfModule>

# ============================================
# GZIP COMPRESSION - Reduce file sizes
# ============================================
<IfModule mod_deflate.c>
    # Compress HTML, CSS, JavaScript, Text, XML and fonts
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/x-font-ttf
    AddOutputFilterByType DEFLATE application/x-font-otf
    AddOutputFilterByType DEFLATE font/truetype
    AddOutputFilterByType DEFLATE font/opentype
    AddOutputFilterByType DEFLATE image/svg+xml

    # Remove browser bugs (only needed for really old browsers)
    BrowserMatch ^Mozilla/4 ^gzip-only-text/html$
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary User-Agent
</IfModule>

# ============================================
# BROWSER CACHING - Long-term caching for static assets
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Cache images for 1 year
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"

    # Cache CSS for 1 year (use cache busting in filenames)
    ExpiresByType text/css "access plus 1 year"

    # Cache JavaScript for 1 year (use cache busting in filenames)
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Cache fonts for 1 year
    ExpiresByType font/truetype "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/x-font-otf "access plus 1 year"

    # Cache JSON for 1 day
    ExpiresByType application/json "access plus 1 day"

    # Don't cache HTML files (always check for updates)
    ExpiresByType text/html "access plus 0 seconds"

    # Default: 1 day
    ExpiresDefault "access plus 1 day"
</IfModule>

# ============================================
# ETAG & CACHE CONTROL HEADERS
# ============================================
<IfModule mod_headers.c>
    # Remove ETag (use Last-Modified instead for better caching)
    Header unset ETag
    FileETag None

    # Cache static assets for 1 year
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|svg|css|js|ttf|otf|woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>

    # Cache fonts from Google Fonts CDN for 1 year
    <FilesMatch "fonts\.(googleapis|gstatic)\.com">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>

    # Don't cache HTML files
    <FilesMatch "\.html?$">
        Header set Cache-Control "max-age=0, must-revalidate, no-cache, no-store"
    </FilesMatch>

    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ============================================
# ENABLE BROTLI COMPRESSION (if available)
# ============================================
<IfModule mod_brotli.c>
    AddOutputFilterByType COMPRESS-BROTLI text/plain
    AddOutputFilterByType COMPRESS-BROTLI text/html
    AddOutputFilterByType COMPRESS-BROTLI text/xml
    AddOutputFilterByType COMPRESS-BROTLI text/css
    AddOutputFilterByType COMPRESS-BROTLI text/javascript
    AddOutputFilterByType COMPRESS-BROTLI application/xml
    AddOutputFilterByType COMPRESS-BROTLI application/xhtml+xml
    AddOutputFilterByType COMPRESS-BROTLI application/rss+xml
    AddOutputFilterByType COMPRESS-BROTLI application/javascript
    AddOutputFilterByType COMPRESS-BROTLI application/x-javascript
    AddOutputFilterByType COMPRESS-BROTLI application/x-font-ttf
    AddOutputFilterByType COMPRESS-BROTLI font/truetype
</IfModule>

# ============================================
# 404 ERROR HANDLING
# ============================================
# ErrorDocument 404 /404.html

# ============================================
# PERFORMANCE TIPS
# ============================================
# NOTE: To maximize cacheing effectiveness:
#
# 1. Use versioned filenames for static assets
#    Example: styles.v123.css, app.v456.js
#    This allows 1-year cache expiry without stale content
#
# 2. Use CDN for images and static assets
#    Already doing with Font Awesome and Google Fonts ✓
#
# 3. Implement Service Workers for offline support
#    Consider for future optimization
#
# 4. Use Content Delivery Network (CDN) for main site
#    Current setup: Self-hosted
#    Recommendation: CloudFlare, AWS CloudFront, or BunnyCDN
# ============================================
